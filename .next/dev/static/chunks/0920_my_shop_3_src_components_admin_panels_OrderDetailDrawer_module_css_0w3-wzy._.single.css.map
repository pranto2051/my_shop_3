.backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(59, 31, 12, 0.55);
  z-index: 840;
  backdrop-filter: blur(4px);
}

.drawer {
  position: fixed;
  top: 0;
  right: 0;
  width: min(680px, 98vw);
  height: 100vh;
  background: var(--parchment);
  z-index: 850;
  box-shadow: -10px 0 30px rgba(0,0,0,0.15);
  display: flex;
  flex-direction: column;
  animation: drawerIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes drawerIn {
  from { transform: translateX(100%); }
  to { transform: translateX(0); }
}

.header {
  height: 64px;
  background: var(--parchment-2);
  border-bottom: 2px solid var(--honey);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  flex-shrink: 0;
}

.headerLeft {
  display: flex;
  align-items: center;
  gap: 12px;
}

.orderId {
  font-family: 'Fira Code', monospace;
  font-size: 14px;
  background: rgba(212, 136, 42, 0.1);
  color: var(--honey);
  padding: 2px 10px;
  border-radius: 20px;
}

.statusBadge {
  padding: 2px 10px;
  border-radius: 20px;
  font-family: 'Bebas Neue', cursive;
  font-size: 12px;
}

.headerTitle {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 18px;
  font-weight: 700;
  color: var(--walnut-deep);
  margin: 0;
}

.closeBtn {
  background: none;
  border: none;
  font-size: 20px;
  color: var(--bark-soft);
  cursor: pointer;
  padding: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.2s;
}

.closeBtn:hover {
  color: var(--walnut);
}

.body {
  flex: 1;
  overflow-y: auto;
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 30px;
}

.section {
  display: flex;
  flex-direction: column;
}

.customerCard {
  background: var(--parchment-3);
  border-left: 4px solid var(--walnut);
  padding: 20px;
  border-radius: 0 12px 12px 0;
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 24px;
  box-shadow: var(--shadow-sm);
}

@media (max-width: 600px) {
  .customerCard { grid-template-columns: 1fr; }
}

.label {
  font-family: 'Bebas Neue', cursive;
  font-size: 11px;
  color: var(--honey);
  text-transform: uppercase;
  display: block;
  margin-bottom: 4px;
}

.customerName {
  font-family: 'Rozha One', serif;
  font-size: 22px;
  color: var(--walnut-deep);
  margin-bottom: 8px;
}

.phoneRow {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  margin-bottom: 12px;
}

.phoneText {
  font-family: 'Fira Code', monospace;
  font-size: 16px;
  color: var(--walnut);
}

.waBtn {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #25D366;
  color: white;
  border: none;
  padding: 6px 14px;
  border-radius: 8px;
  font-size: 13px;
  font-family: 'Noto Sans Bengali', sans-serif;
  cursor: pointer;
  transition: opacity 0.2s;
}

.waBtn:hover { opacity: 0.9; }

.infoRow {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 13px;
  color: var(--bark-mid);
}

.icon { color: var(--honey); }

.accentText { color: var(--honey); font-weight: 600; }

.noteRow {
  margin-top: 10px;
  display: flex;
  gap: 10px;
  padding-top: 10px;
  border-top: 1px solid rgba(0,0,0,0.05);
}

.italic { font-style: italic; color: var(--bark-soft); font-size: 13px; }

.productCard {
  background: var(--parchment-2);
  padding: 20px;
  border-radius: 12px;
  border: 1px solid var(--border);
}

.productHeader {
  display: flex;
  gap: 16px;
  margin-bottom: 20px;
}

.productThumb {
  width: 80px;
  height: 64px;
  border-radius: 10px;
  object-fit: cover;
  background: var(--linen-dark);
}

.productMain { display: flex; flex-direction: column; }

.pName {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--walnut-deep);
}

.pId {
  font-family: 'Fira Code', monospace;
  font-size: 12px;
  color: var(--honey);
}

.pQty {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 13px;
  color: var(--bark-soft);
}

.priceGrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}

.priceItem {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.priceItem span:first-child {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 11px;
  color: var(--bark-soft);
}

.valWalnut { font-family: 'Rozha One', serif; font-size: 18px; color: var(--walnut); }
.valMoss { font-family: 'Noto Sans Bengali', sans-serif; font-size: 14px; color: var(--stage-approved); font-weight: 600; }
.valSienna { font-family: 'Noto Sans Bengali', sans-serif; font-size: 14px; color: var(--stage-cancelled); font-weight: 600; }

.sectionHeader {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 12px;
}

.sectionTitle {
  font-family: 'Rozha One', serif;
  font-size: 20px;
  color: var(--walnut-deep);
  margin: 0;
}

.progressPercent {
  font-family: 'Rozha One', serif;
  font-size: 42px;
  color: var(--honey);
  line-height: 1;
}

.progressBarLarge {
  height: 12px;
  background: var(--linen-dark);
  border-radius: 10px;
  margin-bottom: 30px;
  overflow: hidden;
}

.progressBarFill {
  height: 100%;
  transition: width 0.8s ease-out;
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timelineItem {
  display: flex;
  gap: 20px;
  min-height: 80px;
}

.timelineLeft {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 28px;
}

.timelineCircle {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 2px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 2;
  background: var(--parchment);
}

.current .timelineCircle {
  width: 28px;
  height: 28px;
  border-width: 3px;
  border-color: white !important;
  box-shadow: 0 0 0 4px rgba(0,0,0,0.1);
  animation: stageCurrentPulse 2s ease-in-out infinite;
}

@keyframes stageCurrentPulse {
  0%, 100% { box-shadow: 0 0 0 4px rgba(212, 136, 42, 0.25); }
  50% { box-shadow: 0 0 0 8px rgba(212, 136, 42, 0.1); }
}

.timelineLine {
  width: 2px;
  flex: 1;
  margin: 4px 0;
}

.lineSolid { background: var(--stage-approved); }
.lineDashed { 
  background-image: linear-gradient(to bottom, var(--linen-dark) 50%, rgba(255,255,255,0) 0%);
  background-position: right;
  background-size: 2px 10px;
  background-repeat: repeat-y;
}

.timelineRight {
  flex: 1;
  padding-bottom: 24px;
}

.stageHeader {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 8px;
}

.stageName {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 15px;
  font-weight: 700;
  color: var(--bark-soft);
}

.current .stageName { font-size: 16px; }

.currentBadge {
  font-family: 'Bebas Neue', cursive;
  font-size: 11px;
  background: var(--accent);
  color: white;
  padding: 1px 8px;
  border-radius: 4px;
}

.timestamp {
  font-family: 'Fira Code', monospace;
  font-size: 12px;
  color: var(--bark-soft);
  margin-left: auto;
}

.historyNote {
  background: rgba(74, 124, 89, 0.05);
  border-left: 3px solid;
  padding: 10px 14px;
  border-radius: 0 8px 8px 0;
}

.historyNote p {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 13px;
  color: var(--bark-mid);
  font-style: italic;
  margin: 0 0 4px 0;
}

.completedBy {
  font-family: 'Fira Code', monospace;
  font-size: 10px;
  color: var(--bark-soft);
}

.pendingText {
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  color: var(--bark-soft);
  font-style: italic;
}

.updateSection {
  background: var(--parchment-2);
  padding: 24px;
  border-radius: 16px;
  border: 1px solid var(--border);
  margin-top: 10px;
}

.updateForm {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-top: 20px;
}

.nextStageLabel {
  font-family: 'Bebas Neue', cursive;
  font-size: 12px;
  color: var(--honey);
}

.nextStageCard {
  display: flex;
  gap: 16px;
  padding: 12px 16px;
  border-radius: 10px;
  border: 2px solid;
}

.nextStageIcon { flex-shrink: 0; }

.nextStageName {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 15px;
  font-weight: 700;
  color: var(--walnut-deep);
}

.nextStageDesc {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 13px;
  color: var(--bark-soft);
}

.formGroup {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.inputLabel {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--walnut-deep);
}

.stagePills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.stagePill {
  padding: 6px 14px;
  border-radius: 20px;
  border: 1.5px solid;
  background: white;
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 12px;
  cursor: pointer;
  transition: all 0.2s;
  color: var(--bark-mid);
}

.activePill {
  background: var(--pill-color);
  color: white;
  border-color: var(--pill-color) !important;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

.textarea {
  background: var(--parchment);
  border: 1.5px solid var(--linen-dark);
  border-radius: 10px;
  padding: 14px;
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 14px;
  resize: none;
  outline: none;
  transition: all 0.2s;
}

.textarea:focus {
  border-color: var(--honey);
  box-shadow: 0 0 0 3px rgba(212, 136, 42, 0.12);
}

.charCount {
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  color: var(--bark-soft);
  text-align: right;
}

.templates {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.templateBtn {
  background: none;
  border: 1px solid var(--honey);
  color: var(--honey);
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-family: 'Noto Sans Bengali', sans-serif;
  cursor: pointer;
  transition: all 0.2s;
}

.templateBtn:hover {
  background: var(--honey);
  color: white;
}

.saveBtn {
  height: 52px;
  border-radius: 12px;
  background: linear-gradient(135deg, var(--walnut), var(--honey));
  color: var(--parchment);
  border: none;
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 15px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  cursor: pointer;
  transition: all 0.3s;
  box-shadow: 0 4px 15px rgba(124, 75, 42, 0.2);
}

.saveBtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(124, 75, 42, 0.3);
}

.saveBtn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
  transform: none;
}

.actionButtons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.editBtn, .cancelBtn {
  height: 40px;
  border-radius: 8px;
  border: 1px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s;
}

.editBtn {
  background: white;
  border-color: var(--walnut);
  color: var(--walnut);
}

.editBtn:hover { background: var(--parchment-2); }

.cancelBtn {
  background: white;
  border-color: var(--stage-cancelled);
  color: var(--stage-cancelled);
}

.cancelBtn:hover { background: rgba(181, 84, 30, 0.05); }

.footer {
  height: 60px;
  background: var(--parchment-2);
  border-top: 1px solid var(--honey);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  flex-shrink: 0;
}

.footerInfo {
  display: flex;
  gap: 20px;
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  color: var(--bark-soft);
}

.lastUpdated {
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  color: var(--honey);
}
