.panelContainer {
  padding: 24px;
  max-width: 1200px;
  margin: 0 auto;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
}

.title {
  font-family: 'Rozha One', serif;
  font-size: 32px;
  color: var(--walnut-deep);
  margin: 0;
}

.subtitle {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 13px;
  color: var(--bark-soft);
  margin: 4px 0 0 0;
}

.createBtn {
  display: flex;
  align-items: center;
  gap: 8px;
  background: linear-gradient(135deg, var(--honey), #b57224);
  color: var(--parchment);
  padding: 0 24px;
  height: 44px;
  border-radius: 22px;
  border: none;
  font-family: 'Noto Sans Bengali', sans-serif;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 12px rgba(212, 136, 42, 0.2);
}

.createBtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 15px rgba(212, 136, 42, 0.3);
}

.statsRow {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 30px;
}

.statCard {
  padding: 16px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.statInfo {
  display: flex;
  flex-direction: column;
}

.statLabel {
  font-size: 12px;
  color: var(--bark-soft);
  font-family: 'Noto Sans Bengali', sans-serif;
}

.statValue {
  font-size: 24px;
  font-weight: 700;
  font-family: 'Rozha One', serif;
}

.activeStat { background: rgba(212, 136, 42, 0.1); color: var(--walnut); }
.completedStat { background: rgba(74, 124, 89, 0.1); color: var(--stage-approved); }
.cancelledStat { background: rgba(181, 84, 30, 0.1); color: var(--stage-cancelled); }
.todayStat { background: rgba(200, 120, 10, 0.1); color: var(--stage-cutting); }

.filterRow {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.filterTabs {
  display: flex;
  background: var(--parchment-2);
  padding: 4px;
  border-radius: 30px;
  border: 1px solid var(--border);
}

.filterTab {
  padding: 8px 16px;
  border-radius: 25px;
  border: none;
  background: none;
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  gap: 6px;
  color: var(--bark-mid);
}

.filterTab.activeTab {
  background: var(--walnut-deep);
  color: var(--parchment);
}

.count {
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  opacity: 0.8;
}

.searchBox {
  position: relative;
  flex: 1;
  min-width: 200px;
}

.searchIcon {
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--honey);
  font-size: 14px;
}

.searchBox input {
  width: 100%;
  height: 40px;
  padding: 0 15px 0 40px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background: var(--parchment);
  font-family: 'Fira Code', monospace;
  font-size: 14px;
  outline: none;
  transition: border-color 0.2s;
}

.searchBox input:focus {
  border-color: var(--honey);
}

.sortDropdown select {
  height: 40px;
  padding: 0 15px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background: var(--parchment);
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 13px;
  outline: none;
  cursor: pointer;
}

.orderGrid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

@media (max-width: 900px) {
  .orderGrid { grid-template-columns: 1fr; }
  .statsRow { grid-template-columns: repeat(2, 1fr); }
}

.orderCard {
  background: var(--parchment-2);
  border-radius: 16px;
  border: 1px solid var(--border);
  border-left: 5px solid transparent;
  padding: 20px;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: all 0.25s ease;
  box-shadow: var(--shadow-card);
}

.orderCard:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-left-width: 8px;
}

.cardTop {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.idBadge {
  font-family: 'Fira Code', monospace;
  font-size: 12px;
  background: rgba(212, 136, 42, 0.1);
  color: var(--honey);
  padding: 2px 10px;
  border-radius: 20px;
}

.statusBadge {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border-radius: 20px;
  font-family: 'Bebas Neue', cursive;
  font-size: 12px;
  text-transform: uppercase;
}

.customerName {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--walnut-deep);
  margin-bottom: 12px;
}

.cardMiddle {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16px;
}

.productInfo {
  display: flex;
  gap: 10px;
}

.productThumb {
  width: 48px;
  height: 40px;
  border-radius: 8px;
  object-fit: cover;
  background: var(--linen-dark);
}

.pName {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 13px;
  color: var(--walnut-mid);
  line-height: 1.2;
}

.pQty {
  font-family: 'Fira Code', monospace;
  font-size: 12px;
  color: var(--bark-soft);
}

.customerPhone {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'Fira Code', monospace;
  font-size: 14px;
  color: var(--walnut);
}

.progressSection {
  margin-bottom: 16px;
}

.progressLabel {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  margin-bottom: 8px;
}

.progressLabel span:first-child {
  font-family: 'Noto Sans Bengali', sans-serif;
  color: var(--bark-soft);
}

.progressLabel span:last-child {
  font-family: 'Fira Code', monospace;
  color: var(--honey);
}

.progressBarTrack {
  height: 8px;
  background: var(--linen-dark);
  border-radius: 10px;
  position: relative;
  display: flex;
  align-items: center;
}

.progressBarFill {
  height: 100%;
  border-radius: 10px;
  transition: width 0.8s ease-out;
}

.stageDot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  position: absolute;
  z-index: 2;
  border: 2px solid transparent;
}

.pulsingDot {
  width: 12px;
  height: 12px;
  box-shadow: 0 0 0 4px rgba(212, 136, 42, 0.2);
  animation: dotPulse 2s infinite;
}

@keyframes dotPulse {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.8; }
  100% { transform: scale(1); opacity: 1; }
}

.cardBottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 12px;
  border-top: 1px dashed var(--border);
}

.dateInfo {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.dateItem {
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  color: var(--bark-soft);
}

.amountInfo {
  text-align: right;
}

.totalAmount {
  font-family: 'Rozha One', serif;
  font-size: 18px;
  color: var(--walnut);
  margin-bottom: 2px;
}

.paidAmount {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 11px;
  color: var(--stage-approved);
}

.remainingAmount {
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 11px;
  color: var(--stage-cancelled);
}

.hoverActions {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 36px;
  background: var(--walnut-deep);
  color: var(--parchment);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Noto Sans Bengali', sans-serif;
  font-size: 13px;
  transform: translateY(100%);
  transition: transform 0.25s ease;
}

.orderCard:hover .hoverActions {
  transform: translateY(0);
}
