{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/order-tracking/layout,_N_T_/order-tracking/page,_N_T_/order-tracking"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/order-tracking/__PAGE__",
    "/order-tracking",
    "/_index",
    "/_head"
  ]
}